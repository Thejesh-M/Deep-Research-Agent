"""
Config-driven agent that wraps any deployed HTTP endpoint.

The endpoint is a black-box: it manages its own tools, conversation history,
and session state internally. From tau2's perspective, this agent only
sends and receives text messages.

All endpoint-specific details (URL, payload shape, response parsing, headers)
are driven by an `endpoint_config` dict — typically loaded from YAML.

Usage:
    endpoint_config = {
        "url": "https://your-endpoint.run.app",
        "payload_template": {
            "agent_id": "my-agent",
            "session_id": "{{session_id}}",
            "query": "{{query}}",
        },
        "response_content_key": "content",
    }

    agent = EndpointAgent(
        tools=[],
        domain_policy="",
        endpoint_config=endpoint_config,
    )
"""

import copy
import uuid
from typing import List, Optional

import requests
from loguru import logger

from tau2.agent.base import LocalAgent, ValidAgentInputMessage
from tau2.data_model.message import (
    AssistantMessage,
    Message,
    MultiToolMessage,
    UserMessage,
)
from tau2.data_model.tasks import Task
from tau2.environment.tool import Tool


# ============================================================
# Template rendering helpers
# ============================================================

def render_template(value, variables: dict):
    """Recursively render {{variable}} placeholders in a value."""
    if isinstance(value, str):
        result = value
        for key, val in variables.items():
            result = result.replace("{{" + key + "}}", str(val))
        return result
    elif isinstance(value, dict):
        return {k: render_template(v, variables) for k, v in value.items()}
    elif isinstance(value, list):
        return [render_template(item, variables) for item in value]
    return value


def extract_by_dot_path(data: dict, dot_path: str):
    """
    Extract a value from a nested dict using dot-path notation.
    e.g. "data.response.text" -> data["data"]["response"]["text"]
    """
    keys = dot_path.split(".")
    current = data
    for key in keys:
        if isinstance(current, dict):
            current = current.get(key)
        else:
            return None
        if current is None:
            return None
    return current


# ============================================================
# Agent state
# ============================================================

class EndpointAgentState:
    """State for the endpoint agent — tracks session and conversation for tau2."""

    def __init__(self, session_id: str, messages: list = None):
        self.session_id = session_id
        self.messages = messages or []
        self.system_messages = []


# ============================================================
# Base endpoint agent
# ============================================================

class EndpointAgent(LocalAgent[EndpointAgentState]):
    """
    Config-driven agent that calls any deployed HTTP endpoint.

    endpoint_config keys:
        url (str):                    Endpoint URL (required)
        payload_template (dict):      Request body template with {{query}}, {{session_id}} placeholders
        response_content_key (str):   Dot-path to extract response text from JSON (default: "content")
        method (str):                 HTTP method (default: "POST")
        headers (dict):               HTTP headers (default: {})
        timeout (int):                Request timeout in seconds (default: 120)
    """

    STOP_TOKEN = "###STOP###"

    def __init__(
        self,
        tools: List[Tool],
        domain_policy: str,
        endpoint_config: dict,
    ):
        super().__init__(tools=tools, domain_policy=domain_policy)
        self.endpoint_config = endpoint_config

    @property
    def _url(self) -> str:
        return self.endpoint_config["url"]

    @property
    def _method(self) -> str:
        return self.endpoint_config.get("method", "POST")

    @property
    def _headers(self) -> dict:
        return self.endpoint_config.get("headers", {})

    @property
    def _timeout(self) -> int:
        return self.endpoint_config.get("timeout", 120)

    @property
    def _payload_template(self) -> dict:
        return self.endpoint_config.get("payload_template", {"query": "{{query}}"})

    @property
    def _response_content_key(self) -> str:
        return self.endpoint_config.get("response_content_key", "content")

    def get_init_state(
        self, message_history: Optional[list[Message]] = None
    ) -> EndpointAgentState:
        session_id = str(uuid.uuid4())
        messages = message_history or []
        return EndpointAgentState(session_id=session_id, messages=list(messages))

    def generate_next_message(
        self, message: ValidAgentInputMessage, state: EndpointAgentState
    ) -> tuple[AssistantMessage, EndpointAgentState]:
        if isinstance(message, MultiToolMessage):
            state.messages.extend(message.tool_messages)
            query = str(message.tool_messages[-1].content)
        elif isinstance(message, UserMessage):
            state.messages.append(message)
            query = message.content
        else:
            state.messages.append(message)
            query = str(message.content)

        response_text = self._call_endpoint(
            query=query,
            session_id=state.session_id,
        )

        assistant_message = AssistantMessage(
            role="assistant",
            content=response_text,
            cost=0.0,
        )
        state.messages.append(assistant_message)
        return assistant_message, state

    def _call_endpoint(self, query: str, session_id: str) -> str:
        """Call the endpoint using the configured payload template and response parsing."""
        variables = {
            "query": query,
            "session_id": session_id,
        }
        payload = render_template(copy.deepcopy(self._payload_template), variables)

        try:
            response = requests.request(
                method=self._method,
                url=self._url,
                json=payload,
                headers=self._headers,
                timeout=self._timeout,
            )
            response.raise_for_status()
            data = response.json()
            content = extract_by_dot_path(data, self._response_content_key)
            if content is None:
                logger.warning(
                    f"Key '{self._response_content_key}' not found in response, "
                    f"falling back to full response. Keys: {list(data.keys()) if isinstance(data, dict) else 'N/A'}"
                )
                return str(data)
            return str(content)
        except requests.exceptions.RequestException as e:
            logger.error(f"Endpoint call failed: {e}")
            return f"Error calling endpoint: {e}"

    @classmethod
    def is_stop(cls, message: AssistantMessage) -> bool:
        if message.content and cls.STOP_TOKEN in message.content:
            return True
        return False

    def set_seed(self, seed: int):
        pass


# ============================================================
# No-User (Solo) variant
# ============================================================

class EndpointSoloAgent(EndpointAgent):
    """
    No-User ablation mode.
    Sends the task ticket (question) directly to the endpoint.
    No user interaction — one-shot Q&A.
    """

    def __init__(
        self,
        tools: List[Tool],
        domain_policy: str,
        task: Task,
        endpoint_config: dict,
    ):
        super().__init__(
            tools=tools,
            domain_policy=domain_policy,
            endpoint_config=endpoint_config,
        )
        self.task = task

    @classmethod
    def check_valid_task(cls, task: Task) -> bool:
        return task.ticket is not None

    def generate_next_message(
        self, message: Optional[ValidAgentInputMessage], state: EndpointAgentState
    ) -> tuple[AssistantMessage, EndpointAgentState]:
        if message is None:
            query = self.task.ticket
        elif isinstance(message, UserMessage):
            raise ValueError("Solo agent does not interact with users")
        else:
            if isinstance(message, MultiToolMessage):
                state.messages.extend(message.tool_messages)
            else:
                state.messages.append(message)
            query = str(message.content)

        response_text = self._call_endpoint(
            query=query,
            session_id=state.session_id,
        )

        assistant_message = AssistantMessage(
            role="assistant",
            content=f"{response_text}\n{self.STOP_TOKEN}",
            cost=0.0,
        )
        state.messages.append(assistant_message)
        return assistant_message, state


# ============================================================
# Oracle Plan (GT) variant
# ============================================================

class EndpointGTAgent(EndpointAgent):
    """
    Oracle Plan ablation mode.
    Augments the query with expected answer context using a configurable template,
    reducing the agent's reasoning burden. Still interacts with user simulator.
    """

    DEFAULT_AUGMENTATION_TEMPLATE = (
        "{{query}}\n\n"
        "[Reference guidance - use this to inform your response]: {{expected_answer}}"
    )

    def __init__(
        self,
        tools: List[Tool],
        domain_policy: str,
        task: Task,
        endpoint_config: dict,
        augmentation_template: Optional[str] = None,
    ):
        super().__init__(
            tools=tools,
            domain_policy=domain_policy,
            endpoint_config=endpoint_config,
        )
        self.task = task
        self.expected_answer = self._extract_expected_answer()
        self.augmentation_template = augmentation_template or self.DEFAULT_AUGMENTATION_TEMPLATE

    @classmethod
    def check_valid_task(cls, task: Task) -> bool:
        return task.ticket is not None

    def _extract_expected_answer(self) -> str:
        if hasattr(self.task, "expected_answer"):
            return self.task.expected_answer
        if self.task.evaluation_criteria and self.task.evaluation_criteria.actions:
            return str(self.task.evaluation_criteria.actions)
        return ""

    def generate_next_message(
        self, message: ValidAgentInputMessage, state: EndpointAgentState
    ) -> tuple[AssistantMessage, EndpointAgentState]:
        if isinstance(message, MultiToolMessage):
            state.messages.extend(message.tool_messages)
            query = str(message.tool_messages[-1].content)
        elif isinstance(message, UserMessage):
            state.messages.append(message)
            query = message.content
        else:
            state.messages.append(message)
            query = str(message.content)

        augmented_query = render_template(self.augmentation_template, {
            "query": query,
            "expected_answer": self.expected_answer,
        })

        response_text = self._call_endpoint(
            query=augmented_query,
            session_id=state.session_id,
        )

        assistant_message = AssistantMessage(
            role="assistant",
            content=response_text,
            cost=0.0,
        )
        state.messages.append(assistant_message)
        return assistant_message, state
