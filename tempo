"""
Convert CSV/Excel Q&A pairs into tau2-bench tasks.json format.

Reads your data file, creates Task objects with NL assertion-based evaluation,
and writes them to data/tau2/domains/{domain}/tasks.json — the same structure
used by airline, retail, and telecom domains.

Usage:
    python prepare_tasks.py --config eval_config.yaml

    # Override data path or domain:
    python prepare_tasks.py --config eval_config.yaml --data my_qa.csv --domain mobility

After running this, your tasks are loadable via tau2's standard registry,
and evaluate.py can use run_tasks() directly.
"""

import argparse
import json
from pathlib import Path
from typing import Optional

import pandas as pd
import yaml
from loguru import logger
from pydantic import BaseModel, Field

from eval_harness.endpoint_agent import render_template
from tau2.data_model.tasks import (
    EvaluationCriteria,
    RewardType,
    Task,
    UserScenario,
)
from tau2.utils.utils import DATA_DIR


# ============================================================
# Config (reuse the same YAML schema as evaluate.py)
# ============================================================

class DataConfig(BaseModel):
    path: str
    format: str = "excel"
    columns: dict = Field(default_factory=lambda: {
        "question": "question",
        "expected_answer": "expected_answer",
        "task_id": None,
        "user_persona": None,
    })


class UserSimulatorConfig(BaseModel):
    persona_template: str = "A customer contacting {{domain}} service."
    instructions_template: str = (
        "Ask the following question: {{question}}\n"
        "Once the agent has adequately addressed your question, respond with ###STOP###.\n"
        "If the agent asks clarifying questions, answer naturally."
    )


class PrepareConfig(BaseModel):
    domain: str = "default"
    data: DataConfig
    user_simulator: UserSimulatorConfig = Field(default_factory=UserSimulatorConfig)


def load_config(config_path: str) -> PrepareConfig:
    with open(config_path, "r") as f:
        raw = yaml.safe_load(f)
    return PrepareConfig(**raw)


# ============================================================
# Convert data to tasks
# ============================================================

def convert_to_tasks(config: PrepareConfig) -> list[Task]:
    """Load Q&A pairs and convert to tau2 Task objects."""
    data_cfg = config.data
    col_map = data_cfg.columns

    if data_cfg.format == "csv":
        df = pd.read_csv(data_cfg.path)
    else:
        df = pd.read_excel(data_cfg.path)

    question_col = col_map.get("question", "question")
    answer_col = col_map.get("expected_answer", "expected_answer")
    task_id_col = col_map.get("task_id")
    persona_col = col_map.get("user_persona")

    required = {question_col, answer_col}
    missing = required - set(df.columns)
    if missing:
        raise ValueError(f"Missing columns in data file: {missing}. Found: {list(df.columns)}")

    user_cfg = config.user_simulator
    tasks = []

    for idx, row in df.iterrows():
        question = str(row[question_col]).strip()
        expected_answer = str(row[answer_col]).strip()
        task_id = (
            str(row[task_id_col]).strip()
            if task_id_col and task_id_col in df.columns
            else f"{config.domain}_{idx}"
        )

        template_vars = {
            "question": question,
            "expected_answer": expected_answer,
            "domain": config.domain,
        }

        persona = render_template(user_cfg.persona_template, template_vars)
        if persona_col and persona_col in df.columns:
            persona = str(row[persona_col]).strip()

        instructions = render_template(user_cfg.instructions_template, template_vars)

        task = Task(
            id=task_id,
            user_scenario=UserScenario(
                persona=persona,
                instructions=instructions,
            ),
            ticket=question,
            evaluation_criteria=EvaluationCriteria(
                nl_assertions=[
                    f"The agent's response should be consistent with: {expected_answer}"
                ],
                reward_basis=[RewardType.NL_ASSERTION],
            ),
        )
        tasks.append(task)

    return tasks


# ============================================================
# Write tasks to tau2 data directory
# ============================================================

def save_tasks(tasks: list[Task], domain: str) -> Path:
    """Save tasks to data/tau2/domains/{domain}/tasks.json."""
    domain_dir = DATA_DIR / "tau2" / "domains" / domain
    domain_dir.mkdir(parents=True, exist_ok=True)

    tasks_path = domain_dir / "tasks.json"
    with open(tasks_path, "w") as f:
        json.dump([t.model_dump() for t in tasks], f, indent=2)

    return tasks_path


# ============================================================
# Main
# ============================================================

def main():
    parser = argparse.ArgumentParser(
        description="Convert CSV/Excel Q&A pairs to tau2-bench tasks.json"
    )
    parser.add_argument("--config", required=True, help="Path to YAML config file")
    parser.add_argument("--data", default=None, help="Override data file path")
    parser.add_argument("--domain", default=None, help="Override domain name")
    parser.add_argument("--output", default=None, help="Override output path (default: data/tau2/domains/{domain}/tasks.json)")
    args = parser.parse_args()

    config = load_config(args.config)

    if args.data:
        config.data.path = args.data
    if args.domain:
        config.domain = args.domain

    tasks = convert_to_tasks(config)
    logger.info(f"Converted {len(tasks)} tasks from {config.data.path}")

    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        with open(output_path, "w") as f:
            json.dump([t.model_dump() for t in tasks], f, indent=2)
    else:
        output_path = save_tasks(tasks, config.domain)

    logger.info(f"Saved to {output_path}")
    logger.info(f"Domain '{config.domain}' is now usable with tau2's task registry")


if __name__ == "__main__":
    main()
