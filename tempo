"""
User simulator powered by a LangChain-compatible model (e.g. Gemini wrapper).

The policy/guidelines can be provided inline or as a path to a .md/.txt file,
making this reusable across domains without code changes.

Usage:
    user = GeminiUserSimulator(
        model=your_model,                   # any object with invoke()
        instructions="Ask about pricing.",
        policy="Be natural and helpful.",    # inline string or path to .md file
    )
"""

import os
from typing import Optional, Tuple

from loguru import logger

from tau2.data_model.message import (
    AssistantMessage,
    Message,
    MultiToolMessage,
    SystemMessage,
    UserMessage,
)
from tau2.user.base import (
    STOP,
    TRANSFER,
    OUT_OF_SCOPE,
    BaseUser,
    UserState,
    ValidUserInputMessage,
)


def _load_policy(policy: Optional[str]) -> str:
    """
    Resolve a policy value to its text content.

    - None            -> empty string (no policy)
    - file path       -> read from that file
    - anything else   -> treat as inline policy string
    """
    if policy is None:
        return ""

    if os.path.isfile(policy):
        with open(policy, "r") as fp:
            return fp.read()

    return policy


class GeminiUserSimulator(BaseUser):
    """
    User simulator that uses a LangChain-compatible model.

    The model must have an `invoke()` method that accepts a list of
    LangChain BaseMessage objects and returns a response with a `.content` attribute.
    """

    def __init__(
        self,
        model=None,
        tools=None,
        instructions: Optional[str] = None,
        policy: Optional[str] = None,
        llm: Optional[str] = None,
        llm_args: Optional[dict] = None,
    ):
        super().__init__(instructions=instructions, llm=llm, llm_args=llm_args)
        self.model = model
        self.tools = tools
        self._policy = _load_policy(policy)

    @property
    def system_prompt(self) -> str:
        parts = []
        if self._policy:
            parts.append(self._policy)
        parts.append(f"<scenario>\n{self.instructions}\n</scenario>")
        return "\n\n".join(parts).strip()

    def get_init_state(
        self, message_history: Optional[list[Message]] = None
    ) -> UserState:
        if message_history is None:
            message_history = []
        return UserState(
            system_messages=[SystemMessage(role="system", content=self.system_prompt)],
            messages=list(message_history),
        )

    @classmethod
    def is_stop(cls, message: UserMessage) -> bool:
        if message.is_tool_call():
            return False
        if message.content is None:
            return False
        return (
            STOP in message.content
            or TRANSFER in message.content
            or OUT_OF_SCOPE in message.content
        )

    def generate_next_message(
        self, message: ValidUserInputMessage, state: UserState
    ) -> Tuple[UserMessage, UserState]:
        if isinstance(message, MultiToolMessage):
            state.messages.extend(message.tool_messages)
        else:
            state.messages.append(message)

        langchain_messages = self._build_langchain_messages(state)

        try:
            response = self.model.invoke(langchain_messages)
            response_text = response.content if hasattr(response, "content") else str(response)
        except Exception as e:
            logger.error(f"Model invoke failed: {e}")
            response_text = f"I'm having trouble responding. {STOP}"

        user_message = UserMessage(
            role="user",
            content=response_text,
            cost=0.0,
        )

        state.messages.append(user_message)
        return user_message, state

    def _build_langchain_messages(self, state: UserState) -> list:
        """
        Convert tau2 state into LangChain message format.

        Role-flipping: the user simulator sees agent messages as input (HumanMessage)
        and its own previous messages as output (AIMessage).
        """
        from langchain_core.messages import SystemMessage as LCSystem
        from langchain_core.messages import HumanMessage, AIMessage

        lc_messages = []

        for sys_msg in state.system_messages:
            lc_messages.append(LCSystem(content=sys_msg.content))

        for msg in state.messages:
            if isinstance(msg, AssistantMessage):
                if msg.content and not msg.is_tool_call():
                    lc_messages.append(HumanMessage(content=msg.content))
            elif isinstance(msg, UserMessage):
                lc_messages.append(AIMessage(content=msg.content or ""))

        return lc_messages

    def set_seed(self, seed: int):
        pass
