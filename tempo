"""
Config-driven evaluation harness for deployed agents.

Reuses tau2-bench's native pipeline:
  - Tasks are pre-converted via prepare_tasks.py into data/tau2/domains/{domain}/tasks.json
  - Calls run_tasks() for trial orchestration, checkpoint/resume, concurrency
  - Uses NLAssertionsEvaluator for LLM-as-judge scoring
  - Uses compute_metrics() for pass@k computation
  - Uses ConsoleDisplay for results presentation

Prerequisites:
    python prepare_tasks.py --config eval_config.yaml

Usage:
    python evaluate.py --config eval_config.yaml
    python evaluate.py --config eval_config.yaml --mode no_user --num-trials 4

See eval_config.example.yaml for a fully commented config template.
"""

import argparse
from pathlib import Path
from typing import Optional

import yaml
from loguru import logger
from pydantic import BaseModel, Field

from tau2.environment.environment import Environment
from tau2.evaluator.evaluator import EvaluationType
from tau2.metrics.agent_metrics import compute_metrics
from tau2.registry import registry
from tau2.run import get_tasks, run_tasks
from tau2.utils.display import ConsoleDisplay
from tau2.utils.utils import DATA_DIR


# ============================================================
# 1. CONFIG SCHEMA
# ============================================================

class EndpointConfig(BaseModel):
    url: str
    method: str = "POST"
    headers: dict = Field(default_factory=dict)
    timeout: int = 120
    payload_template: dict = Field(default_factory=lambda: {"query": "{{query}}"})
    response_content_key: str = "content"


class EvaluationConfig(BaseModel):
    modes: list[str] = Field(default_factory=lambda: ["no_user"])
    num_trials: int = 1
    max_steps: int = 20
    pass_threshold: float = 0.5
    output: str = "evaluation_results.json"
    num_tasks: Optional[int] = None
    seed: int = 42
    max_concurrency: int = 1


class OraclePlanConfig(BaseModel):
    augmentation_template: str = (
        "{{query}}\n\n"
        "[Reference guidance - use this to inform your response]: {{expected_answer}}"
    )


class EvalConfig(BaseModel):
    domain: str = "default"
    endpoint: EndpointConfig
    evaluation: EvaluationConfig = Field(default_factory=EvaluationConfig)
    oracle_plan: OraclePlanConfig = Field(default_factory=OraclePlanConfig)


def load_config(config_path: str) -> EvalConfig:
    with open(config_path, "r") as f:
        raw = yaml.safe_load(f)
    return EvalConfig(**raw)


# ============================================================
# 2. REGISTER CUSTOM DOMAIN (environment only — tasks from disk)
# ============================================================

def register_components(domain_name: str):
    """Register custom agent, user, domain environment, and task loader."""
    from eval_harness.endpoint_agent import EndpointAgent
    from eval_harness.gemini_user import GeminiUserSimulator

    if "endpoint_agent" not in registry.get_agents():
        registry.register_agent(EndpointAgent, "endpoint_agent")
    if "gemini_user" not in registry.get_users():
        registry.register_user(GeminiUserSimulator, "gemini_user")

    def get_environment(**_kwargs) -> Environment:
        return Environment(
            domain_name=domain_name,
            policy="",
            tools=None,
            user_tools=None,
        )

    if domain_name not in registry.get_domains():
        registry.register_domain(get_environment, domain_name)

    if domain_name not in registry.get_task_sets():
        from tau2.utils.io_utils import load_file

        tasks_path = DATA_DIR / "tau2" / "domains" / domain_name / "tasks.json"

        def task_loader(task_split_name: Optional[str] = None):  # noqa: ARG001
            from tau2.data_model.tasks import Task
            raw = load_file(tasks_path)
            tasks = [Task.model_validate(t) for t in raw]
            return tasks

        registry.register_tasks(task_loader, domain_name)


# ============================================================
# 3. MODEL FACTORY — EDIT THIS FOR YOUR SETUP
# ============================================================

def create_user_model():
    """
    Create your LangChain-compatible model instance.

    This is the ONLY function you need to edit when switching environments.
    The model must have an `invoke(messages)` method returning an object
    with a `.content` attribute.
    """
    from langchain_google_genai import ChatGoogleGenerativeAI
    return ChatGoogleGenerativeAI(model="gemini-2.0-flash")


# ============================================================
# 4. BIND MODEL TO USER CLASS
# ============================================================

def bind_user_model(model) -> str:
    """
    Create a user class with the model pre-bound.

    run_task() instantiates the user with (tools, instructions, llm, llm_args).
    We need the model available, so we create a subclass with it baked in.
    """
    from eval_harness.gemini_user import GeminiUserSimulator

    class BoundGeminiUser(GeminiUserSimulator):
        def __init__(self, tools=None, instructions=None, llm=None, llm_args=None):
            super().__init__(
                model=model,
                tools=tools,
                instructions=instructions,
                llm=llm,
                llm_args=llm_args,
            )

    if "gemini_user_bound" not in registry.get_users():
        registry.register_user(BoundGeminiUser, "gemini_user_bound")
    else:
        registry._users["gemini_user_bound"] = BoundGeminiUser

    return "gemini_user_bound"


# ============================================================
# 5. AGENT KWARGS PER MODE
# ============================================================

def get_agent_kwargs(mode: str, config: EvalConfig) -> dict:
    """Build the extra kwargs passed to EndpointAgent via llm_args_agent."""
    kwargs = {
        "endpoint_config": config.endpoint.model_dump(),
        "mode": mode,
    }
    if mode == "oracle_plan":
        kwargs["augmentation_template"] = config.oracle_plan.augmentation_template
    return kwargs


# ============================================================
# 6. MAIN
# ============================================================

def main():
    parser = argparse.ArgumentParser(
        description="Config-driven evaluation harness for deployed agents"
    )
    parser.add_argument("--config", required=True, help="Path to YAML config file")
    parser.add_argument("--mode", default=None, help="Override mode(s): no_user, default, oracle_plan, all")
    parser.add_argument("--num-tasks", type=int, default=None, help="Override number of tasks")
    parser.add_argument("--num-trials", type=int, default=None, help="Override number of trials per task")
    parser.add_argument("--output", default=None, help="Override output file path")
    parser.add_argument("--seed", type=int, default=None, help="Override random seed")
    parser.add_argument("--max-concurrency", type=int, default=None, help="Override max concurrent simulations")
    args = parser.parse_args()

    config = load_config(args.config)

    # Apply CLI overrides
    if args.mode:
        config.evaluation.modes = [args.mode] if args.mode != "all" else ["no_user", "default", "oracle_plan"]
    if args.num_tasks is not None:
        config.evaluation.num_tasks = args.num_tasks
    if args.num_trials is not None:
        config.evaluation.num_trials = args.num_trials
    if args.output:
        config.evaluation.output = args.output
    if args.seed is not None:
        config.evaluation.seed = args.seed
    if args.max_concurrency is not None:
        config.evaluation.max_concurrency = args.max_concurrency

    modes = config.evaluation.modes
    if "all" in modes:
        modes = ["no_user", "default", "oracle_plan"]

    # Register domain (environment + task loader from disk)
    register_components(config.domain)

    # Load tasks via tau2's standard pipeline
    tasks = get_tasks(
        task_set_name=config.domain,
        num_tasks=config.evaluation.num_tasks,
    )

    # Create and bind user model
    user_model = create_user_model()
    user_name = bind_user_model(user_model)

    logger.info(f"Configuration: {len(tasks)} tasks x {config.evaluation.num_trials} trials")

    output_base = Path(config.evaluation.output)

    for mode in modes:
        logger.info(f"\n{'='*60}\nRunning mode: {mode}\n{'='*60}")

        agent_kwargs = get_agent_kwargs(mode, config)
        save_to = output_base.with_suffix(f".{mode}.json")

        # no_user mode uses DummyUser (EndpointAgent handles solo internally)
        current_user = "dummy_user" if mode == "no_user" else user_name

        results = run_tasks(
            domain=config.domain,
            tasks=tasks,
            agent="endpoint_agent",
            user=current_user,
            llm_agent=None,
            llm_args_agent=agent_kwargs,
            llm_user=None,
            llm_args_user=None,
            num_trials=config.evaluation.num_trials,
            max_steps=config.evaluation.max_steps,
            max_errors=5,
            save_to=save_to,
            console_display=True,
            evaluation_type=EvaluationType.NL_ASSERTIONS,
            max_concurrency=config.evaluation.max_concurrency,
            seed=config.evaluation.seed,
            log_level="INFO",
        )

        metrics = compute_metrics(results)
        ConsoleDisplay.display_agent_metrics(metrics)
        logger.info(f"Results saved to {save_to}")


if __name__ == "__main__":
    main()
